{
  "name": "pilcrow-client",
  "version": "0.0.1",
  "description": "Client application for pilcrow",
  "productName": "Pilcrow Client",
  "author": "MESH Research <mesh@msu.edu>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"See package.json => scripts for available tests.\" && exit 0",
    "push:cdn": "f() { s3cmd del $1 --recursive --force && s3cmd put -rP --no-mime-magic --guess-mime-type ./dist/spa/ $1;}; f",
    "dev": "quasar dev",
    "build": "quasar build",
    "client:test": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "postinstall": "node -e \"process.env.NO_POSTINSTALL===1&&process.exit(1)\" || quasar prepare",
    "graphql:fetch-schema": "lando artisan lighthouse:print-schema --no-ansi --sort > src/graphql/schema.graphql",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "graphql:codegen-local": "GRAPHQL_SCHEMA=src/graphql/schema.graphql graphql-codegen --config codegen.ts",
    "graphql:codegen-offline": "yarn graphql:fetch-schema && yarn graphql:codegen-local"
  },
  "dependencies": {
    "@apollo/client": "^3.7.2",
    "@quasar/extras": "^1.15.8",
    "@quasar/quasar-ui-qiconpicker": "^2.0.6",
    "@tiptap/extension-highlight": "^2.0.3",
    "@tiptap/extension-link": "^2.0.3",
    "@tiptap/extension-placeholder": "^2.0.3",
    "@tiptap/pm": "^2.0.3",
    "@tiptap/starter-kit": "^2.0.3",
    "@tiptap/vue-3": "^2.0.3",
    "@vue/apollo-composable": "^4.0.0-beta.1",
    "@vue/apollo-option": "^4.0.0-alpha.20",
    "@vuelidate/core": "^2.0.0",
    "@vuelidate/validators": "^2.0.0",
    "@vueuse/core": "^14.0.0",
    "apollo-upload-client": "^18.0.0",
    "core-js": "^3.29.1",
    "flat": "^6.0.0",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "javascript-time-ago": "^2.5.9",
    "lodash": "^4.17.21",
    "luxon": "^3.3.0",
    "quasar": "^2.6.0",
    "validator": "^13.11.0",
    "vue": "^3.0.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^5.0.0",
    "vuedraggable": "^4.1.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@quasar/app-vite": "^2.0.0",
    "@types/validator": "^13.15.10",
    "@vitest/eslint-plugin": "^1.2.2",
    "@vitest/ui": "^4.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.0.0",
    "autoprefixer": "^10.4.2",
    "axe-core": "4.11.0",
    "axios": "^1.3.4",
    "cypress": "^13.0.0",
    "cypress-axe": "^1.4.0",
    "cypress-file-upload": "^5.0.8",
    "eslint": "10",
    "eslint-plugin-cypress": "^6.0.0",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^17.0.0",
    "happy-dom": "^18.0.0",
    "mock-apollo-client": "^1.2.1",
    "postcss": "^8.4.14",
    "prettier": "3",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.54.0",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-eslint2": "^5.1.0",
    "vite-plugin-graphql-codegen": "^3.8.0",
    "vitest": "^4.0.0",
    "vue-composable-tester": "^0.1.3",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": "^22.0.0 || ^20.0.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
